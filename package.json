    "dev": "concurrently --names \"API,WEB\" --prefix-colors \"blue,green\" \"nodemon Server/server.js\" \"npm run dev --prefix Client\"",
    "start": "node Server/server.js",
    "start:all": "concurrently --names \"API,WEB\" --prefix-colors \"blue,green\" \"node Server/server.js\" \"npm run start --prefix Client\"",
    "build": "npm install && npm install --prefix Client && npm run build --prefix Client",
    "install:all": "npm install && npm install --prefix Client"
  },
